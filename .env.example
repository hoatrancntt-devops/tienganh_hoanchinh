# =============================================================
#  English@Work — sao chép thành .env rồi sửa
#  cp .env.example .env    (hoặc: make env)
# =============================================================

# --- BẮT BUỘC -----------------------------------------------
# Sinh bằng: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ĐẶT MỘT LẦN VÀ ĐỪNG ĐỔI. Mọi API key admin nhập trên web được mã hoá bằng
# khoá dẫn xuất từ đây. Đổi SECRET_KEY = mất toàn bộ secret trong DB, và app
# sẽ im lặng coi như chưa cấu hình chứ không báo lỗi.
SECRET_KEY=

# Mật khẩu Postgres. Chỉ dùng trong mạng nội bộ Docker nhưng vẫn phải đặt tử tế.
POSTGRES_PASSWORD=
POSTGRES_USER=efw
POSTGRES_DB=efw

# --- ADMIN --------------------------------------------------
# Tài khoản admin đầu tiên, tạo lúc khởi động. Để trống = không tạo admin.
# ĐỔI MẬT KHẨU sau lần đăng nhập đầu.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- APP ----------------------------------------------------
APP_ENV=prod              # prod | dev  (prod: tắt /docs, bật cookie secure)
APP_PORT=9999
DEBUG=false
DEFAULT_TZ=Asia/Ho_Chi_Minh
SCHEDULER_ENABLED=true

# --- SPEECH -------------------------------------------------
SPEECH_ENABLED=true
# small = cân bằng tốt nhất cho accent Việt trên 8GB. Máy yếu: base.
WHISPER_MODEL=small
WHISPER_COMPUTE=int8
WHISPER_THREADS=2
# ĐỪNG tăng trên máy 8GB — thứ duy nhất chặn máy swap khi nhiều người ghi âm.
SPEECH_MAX_CONCURRENT=2
SPEECH_IDLE_UNLOAD_S=600

# --- AI (TÙY CHỌN) ------------------------------------------
# App chạy đầy đủ khi KHÔNG có key nào. Cách khuyên dùng: để trống ở đây,
# nhập key trên web tại /admin/settings/ai (mã hoá trước khi lưu DB).
# Định dạng: provider:model,provider:model  (theo thứ tự ưu tiên)
# Provider: anthropic | openai | gemini | openrouter | ollama | azure_openai
LLM_ROUTE_T1=
LLM_ROUTE_T2=
AI_GLOBAL_MONTHLY_USD=20
AI_USER_DAILY_CALLS=20

# --- EMAIL --------------------------------------------------
# Không có biến ở đây. Cấu hình Microsoft 365 (OAuth 2.0) hoặc SMTP trên web
# tại /admin/settings/mail — client secret được mã hoá trong DB.
